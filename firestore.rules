rules_version = '2';
service cloud.firestore {
  // Default deny — specific matches below override this.
  // Firestore grants access if ANY matching allow rule permits it.
  match /{document=**} {
    allow read, write: if false;
  }

  function isSignedIn() { return request.auth != null; }
  function isOwner(data) { return isSignedIn() && data.ownerId == request.auth.uid; }
  function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
  function incoming() { return request.resource.data; }
  function existing() { return resource.data; }

  function isValidJob(data) {
    return data.title is string && data.title.size() <= 200 &&
           data.dept is string && data.dept.size() <= 200 &&
           data.jd is string && data.jd.size() <= 50000 &&
           data.status in ['running', 'paused', 'closed'] &&
           data.ownerId is string;
  }

  function isValidResult(data) {
    return data.jobId is string && isValidId(data.jobId) &&
           data.overall_score is number && data.overall_score >= 0 && data.overall_score <= 100 &&
           data.candidate_name is string &&
           data.ownerId is string;
  }

  match /jobs/{jobId} {
    allow get: if existing().isPublic == true || isOwner(existing());
    allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    allow create: if isSignedIn() && isValidJob(incoming()) && incoming().ownerId == request.auth.uid;
    allow update: if isOwner(existing()) && isValidJob(incoming()) && incoming().ownerId == existing().ownerId;
    allow delete: if isOwner(existing());
  }

  match /analysisResults/{resultId} {
    function canAccessParentJob(jobId) {
      let job = get(/databases/$(database)/documents/jobs/$(jobId));
      return job.data.isPublic == true || (isSignedIn() && job.data.ownerId == request.auth.uid);
    }

    allow get: if isOwner(existing()) || canAccessParentJob(existing().jobId);
    allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    allow create: if isSignedIn() && isValidResult(incoming()) && incoming().ownerId == request.auth.uid && canAccessParentJob(incoming().jobId);
    // HR override: only allow updating hr_override_score and hr_feedback_tags
    allow update: if isOwner(existing()) && isValidResult(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['hr_override_score', 'hr_feedback_tags']);
    allow delete: if isOwner(existing());
  }

  match /test/connection {
    allow read: if true;
  }
}
