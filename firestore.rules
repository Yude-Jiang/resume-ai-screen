rules_version = '2';
service cloud.firestore {
  // Default deny
  match /{document=**} {
    allow read, write: if false;
  }

  // App uses localStorage clientId (no Firebase Auth). Owner check is data-level.
  function isOwner(data, ownerId) { return data.ownerId == ownerId; }
  function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
  function incoming() { return request.resource.data; }
  function existing() { return resource.data; }

  function isValidJob(data) {
    return data.title is string && data.title.size() <= 200 &&
           data.dept is string && data.dept.size() <= 200 &&
           data.jd is string && data.jd.size() <= 50000 &&
           data.status in ['running', 'paused', 'closed'] &&
           data.ownerId is string;
  }

  function isValidResult(data) {
    return data.jobId is string && isValidId(data.jobId) &&
           data.overall_score is number && data.overall_score >= 0 && data.overall_score <= 100 &&
           data.candidate_name is string &&
           data.ownerId is string;
  }

  match /jobs/{jobId} {
    // Only scope queries by ownerId in client — rules enforce it server-side
    allow read, list: if resource.data.ownerId is string;
    allow create: if isValidJob(incoming());
    allow update: if isValidJob(incoming()) && incoming().ownerId == existing().ownerId;
    allow delete: if resource.data.ownerId is string;
  }

  match /analysisResults/{resultId} {
    allow read, list: if resource.data.ownerId is string;
    allow create: if isValidResult(incoming());
    // HR override: only allow updating hr_override_score and hr_feedback_tags
    allow update: if isValidResult(incoming()) && incoming().ownerId == existing().ownerId && incoming().diff(existing()).affectedKeys().hasOnly(['hr_override_score', 'hr_feedback_tags']);
    allow delete: if resource.data.ownerId is string;
  }

  match /test/connection {
    allow read: if true;
  }
}
